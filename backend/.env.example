# Local default (SQLite quick-start)
DB_URL=sqlite:///./viru.db

# Postgres (recommended for local/staging/prod)
# DB_URL=postgresql+psycopg://viru:${DB_PASSWORD}@127.0.0.1:5432/viru

JWT_SECRET=change-me
JWT_ALG=HS256
ACCESS_TOKEN_MINUTES=30
APP_ENV=local

# Bootstrap flags (disable in staging/prod once migrations are in use)
RUN_DB_INIT=false
RUN_SEED_USERS=false
