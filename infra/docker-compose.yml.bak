version: "3.9"
services:
  backend:
    build:
      context: ..
      dockerfile: infra/docker/backend.Dockerfile
    env_file:
      - ../backend/.env.example
    environment:
      JWT_SECRET: viru-local-dev-secret-please-change
    ports:
      - "8000:8000"
    volumes:
      - ../backend:/app
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')"]
      interval: 20s
      timeout: 5s
      retries: 5

  frontend:
    build:
      context: ..
      dockerfile: infra/docker/frontend.Dockerfile
    ports:
      - "3000:3000"
    volumes:
      - ../frontend:/app
    environment:
      NEXT_PUBLIC_API_URL: http://localhost:8000/api/v1
    depends_on:
      backend:
        condition: service_healthy

  db:
    image: postgres:16
    environment:
      POSTGRES_USER: viru
      POSTGRES_PASSWORD: viru
      POSTGRES_DB: viru

  redis:
    image: redis:7
