{
    "mcpServers": {
        "TestSprite": {
            "command": "npx",
            "args": ["@testsprite/testsprite-mcp@latest"],
            "env": {
                "API_KEY": "${TESTSPRITE_API_KEY}"
            }
        },
        "lazyweb": {
            "type": "streamable-http",
            "url": "https://www.lazyweb.com/mcp",
            "headers": {
                "Authorization": "Bearer ${LAZYWEB_TOKEN}"
            }
        }
    }
}
