[
  {
    "id": "TC001",
    "title": "Create a new alert and verify it appears in the alerts list",
    "description": "Verifies an authenticated user can create a new alert and see it in the list.",
    "category": "Alert Management",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Log in\" button"
      },
      {
        "type": "action",
        "description": "Click on \"Alerts\" in the main navigation"
      },
      {
        "type": "assertion",
        "description": "Verify page title contains \"Alerts\""
      },
      {
        "type": "action",
        "description": "Click the \"Create new alert\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Create Alert\" is visible"
      },
      {
        "type": "action",
        "description": "Fill \"Test Alert - Price Drop\" into the \"Alert name\" field"
      },
      {
        "type": "action",
        "description": "Select \"Price\" from the \"Category\" dropdown"
      },
      {
        "type": "action",
        "description": "Fill \"100\" into the \"Threshold\" field"
      },
      {
        "type": "action",
        "description": "Click the \"Save\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Test Alert - Price Drop\" is visible"
      }
    ]
  },
